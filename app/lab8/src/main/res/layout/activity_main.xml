<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#ECEFF1">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lab 8 - ROOM Database"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- Butoane principale -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnAdauga"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Adauga"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnAfiseazaToate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Afiseaza toate"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Card pentru cautare/filtrare -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cautare si Filtrare"
                android:textStyle="bold"
                android:textColor="#5C6BC0"
                android:layout_marginBottom="8dp"/>

            <!-- 3. Cautare dupa marca -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etCautareMarca"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Marca (ex: Samsung)"
                    android:inputType="text"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnCautaMarca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Cauta"/>

            </LinearLayout>

            <!-- 4. Filtrare dupa interval diagonala -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etDiagMin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Min"
                    android:inputType="number"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp"/>

                <EditText
                    android:id="@+id/etDiagMax"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Max"
                    android:inputType="number"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnFiltreazaDiag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. Interval"/>

            </LinearLayout>

            <!-- 6. Creste diagonala pentru marca care incepe cu litera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etLitera"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Litera (ex: S)"
                    android:inputType="text"
                    android:maxLength="1"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnCresteDialonala"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6. Creste diag"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card pentru stergere -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stergere"
                android:textStyle="bold"
                android:textColor="#E53935"
                android:layout_marginBottom="8dp"/>

            <!-- 5. Stergere dupa pret -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etPretStergere"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Pret limita"
                    android:inputType="numberDecimal"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnStergePretMare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5a. Pret >"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnStergePretMic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5b. Pret &lt;"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lista televizoarelor:"
        android:textStyle="italic"
        android:textColor="#455A64"
        android:layout_marginBottom="4dp"/>

    <!-- Lista TV-uri -->
    <ListView
        android:id="@+id/listViewTV"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"/>

</LinearLayout>
