<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLU -->
        <TextView
            android:id="@+id/tvTitlu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📺 Adaugă TV"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <!-- CARD: Informații generale -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Informații generale"
                    android:textSize="14sp"
                    android:textColor="#5C6BC0"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marcă"
                    android:textColor="#455A64"
                    android:textSize="13sp"/>

                <EditText
                    android:id="@+id/etMarca"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: Samsung, LG, Sony"
                    android:inputType="text"
                    android:background="@android:drawable/editbox_background"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diagonală (inch)"
                    android:textColor="#455A64"
                    android:textSize="13sp"/>

                <EditText
                    android:id="@+id/etDiagonala"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: 55"
                    android:inputType="number"
                    android:background="@android:drawable/editbox_background"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tip panou"
                    android:textColor="#455A64"
                    android:textSize="13sp"/>

                <Spinner
                    android:id="@+id/spinnerTipPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/btn_dropdown"
                    android:padding="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARD: Caracteristici -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Caracteristici"
                    android:textSize="14sp"
                    android:textColor="#5C6BC0"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <CheckBox
                    android:id="@+id/cbSmartTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Este Smart TV"
                    android:textColor="#37474F"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Condiție"
                    android:textColor="#455A64"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>

                <RadioGroup
                    android:id="@+id/rgConditie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rbNou"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nou"
                        android:checked="true"
                        android:textColor="#37474F"/>

                    <RadioButton
                        android:id="@+id/rbFolosit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Folosit"
                        android:layout_marginStart="24dp"
                        android:textColor="#37474F"/>

                </RadioGroup>

                <Switch
                    android:id="@+id/switchDisponibil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disponibil în stoc"
                    android:textColor="#37474F"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp"/>

                <ToggleButton
                    android:id="@+id/togglePromotie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textOn="🏷️ Promoție ACTIVĂ"
                    android:textOff="Fără promoție"
                    android:background="#C5CAE9"
                    android:textColor="#1A237E"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARD: Rating -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ Rating"
                    android:textSize="14sp"
                    android:textColor="#5C6BC0"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="0.5"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARD: Data achizitie -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Data achiziției"
                    android:textSize="14sp"
                    android:textColor="#5C6BC0"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BUTON SALVARE -->
        <Button
            android:id="@+id/btnSalveaza"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✅ Salvează TV"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3949AB"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>